APP_ENV=test
APP_SECRET=test_secret

# SQLite en mémoire : rapide, isolé, sans Docker
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# Emails capturés en mémoire (aucun envoi réel)
MAILER_DSN=null://null

# Messages traités de façon synchrone en test (voir messenger.yaml when@test)
MESSENGER_TRANSPORT_DSN=in-memory://
